modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd artifacts/api-server && node --enable-source-maps ./dist/index.mjs"]
build = ["bash", "-c", "pnpm install --frozen-lockfile && pnpm --filter @workspace/db run push && pnpm --filter @workspace/examverse run build && pnpm --filter @workspace/api-server run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Examverse"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Examverse"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=23432 BASE_PATH=/ pnpm --filter @workspace/examverse run dev"
waitForPort = 23432

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_gemini_ai_integrations:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 23432
externalPort = 3002

[[ports]]
localPort = 23480
externalPort = 3000

[nix]
channel = "stable-25_05"
